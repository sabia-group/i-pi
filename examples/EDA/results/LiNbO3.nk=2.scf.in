&CONTROL
  calculation = 'scf'
  restart_mode= 'from_scratch'
  prefix      = 'LiNbO3'
  pseudo_dir  = '/home/elia/Google-Drive/google-personal/pseudos'
  outdir      = './outdir/LiNbO3.nk=2'
  tprnfor     = .true.
  !tstress     = .true.
  verbosity   = 'high'
  !lelfield    = .true.
  !max_seconds = 7100
  !etot_conv_thr = 1.0D-4
  !forc_conv_thr = 1.0D-3
/
&SYSTEM
  ecutwfc = 100
  ecutrho = 800
  ibrav = 0
  nat   = 30
  ntyp  = 3
  occupations = 'fixed'
/
&ELECTRONS
  !mixing_mode = 'local-TF'
  !mixing_beta = 0.9
  mixing_ndim=25
  diagonalization = 'davidson' !ppcg, paro
  diago_david_ndim = 4
  conv_thr = 1.0D-10
  ! diago_thr_init = 1.0D-4
  electron_maxstep=300
  startingpot = 'file'
  startingwfc = 'file'
/
&IONS
  upscale = 10
  pot_extrapolation = 'second_order'
  wfc_extrapolation = 'second_order'
/
&CELL
  cell_dofree = 'all'

ATOMIC_SPECIES
  Nb  92.90638 Nb.pbesol-spn-rrkjus_psl.1.0.0.UPF
