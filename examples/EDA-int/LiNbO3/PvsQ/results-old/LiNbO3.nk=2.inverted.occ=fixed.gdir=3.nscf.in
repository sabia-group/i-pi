&CONTROL
  calculation = 'nscf'
  restart_mode= 'from_scratch'
  prefix      = 'LiNbO3'
  pseudo_dir  = '/home/elia/Google-Drive/google-personal/pseudos'
  outdir      = './outdir/LiNbO3.nk=2.inverted'
  !tprnfor     = .true.
  !tstress     = .true.
  verbosity   = 'high'
  !lelfield    = .true.
  !max_seconds = 14000
  lberry = .true.
  gdir = 3
  nppstr = 2

/
&SYSTEM
  ecutwfc = 80
  ecutrho = 320
  ibrav = 0
  nat = 10
  ntyp = 3
  !nspin=2
  occupations = 'fixed'
  smearing='gauss'
  degauss=0.005
/
&ELECTRONS
  mixing_mode = 'local-TF'
  conv_thr = 1.0D-5
  mixing_beta = 0.9
  mixing_ndim=25
  electron_maxstep=100
  startingpot = 'file'
  startingwfc = 'file'
/
