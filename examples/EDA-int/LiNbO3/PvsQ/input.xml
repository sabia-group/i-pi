<simulation verbosity='medium'>

  <total_steps>1000</total_steps>

  <ffsocket mode='unix' name='FHI-aims' pbc='False'>
    <address>symmetric</address>
    <!--port>0000</port-->
    <!--timeout>100</timeout-->
    <!--latency> 0.01</latency-->
  </ffsocket>

  <output prefix='LiNbO3'>
    <!--trajectory filename='position'>positions</trajectory-->
    <properties filename='properties.out' > [ step, time{femtosecond}, conserved, temperature{kelvin} ] </properties>
  </output>

  <prng>
    <seed>10545</seed>
  </prng>

  <system>
    <forces> <force forcefield='FHI-aims'/> </forces>

    <initialize nbeads='1'>
      <!--file mode='aims' units='angstrom' cell_units='angstrom' > geometry.in </file-->
      <file mode='xyz' units='angstrom' > LiNbO3.xyz </file>
      <velocities mode='thermal' units='kelvin'>30</velocities>
      <cell mode="manual" units="angstrom">[  4.2442209319436959, 1.6346114044445832, 3.0825805539430258,
       0.0000000000000000, 4.5481196540733295, 3.0825782703885887,
       0.0000000000000000, 0.0000000000000000, 5.4943305901844859  ]</cell>
    </initialize>

    <!--ensemble>
      <temperature units='kelvin'>30</temperature>
    </ensemble-->

    <motion mode='vibrations'>
      <vibrations>
        <pos_shift>  0.01 </pos_shift>
      </vibrations>
    </motion>

  </system>
</simulation>
