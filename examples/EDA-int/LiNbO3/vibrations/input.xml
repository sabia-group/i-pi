<simulation verbosity='high'>

  <total_steps>1000</total_steps>

  <ffsocket mode='unix' name='pw' pbc='False'>
    <address>vibrations</address>
    <!--port>0000</port-->
    <!--timeout>100</timeout-->
    <!--latency> 0.01</latency-->
  </ffsocket>

  <output prefix='LiNbO3.qe'>
    <!--trajectory filename='polarization'>polarization</trajectory-->
    <!--trajectory filename='position'>positions</trajectory-->
    <!--properties filename='properties.out' > [ step, time{femtosecond}, conserved, temperature{kelvin}] </properties-->
  </output>

  <prng>
    <seed>10545</seed>
  </prng>

  <system>
    <forces> <force forcefield='pw'/> </forces>

    <initialize nbeads='1'>
      <file mode='xyz' units='angstrom' > LiNbO3.xyz </file>
      <velocities mode='thermal' units='kelvin'>30</velocities>
      <cell mode="manual" units="angstrom">[  4.24102999660546, 1.63392996111767, 3.08247152070467,
        0.00000000000000, 4.54490544781247, 3.08244612716667,
        0.00000000000000, 0.00000000000000, 5.49157234881015  ]</cell>
    </initialize>

    <motion mode='vibrations'>
      <vibrations>
        <pos_shift>  0.01 </pos_shift>
      </vibrations>
    </motion>

  </system>
</simulation>
