&CONTROL
  calculation = 'scf'
  restart_mode= 'from_scratch'
  prefix      = 'LiNbO3'
  pseudo_dir  = '/home/elia/Google-Drive/google-personal/pseudos'
  outdir      = './outdir/LiNbO3.nk=3'
  !tprnfor     = .true.
  !tstress     = .true.
  verbosity   = 'high'
  !max_seconds = 14000
/
&SYSTEM
  ecutwfc = 80
  ecutrho = 320
  ibrav = 0
  nat = 10
  ntyp = 3
  !nspin=2
  occupations = 'fixed'
  smearing='gauss'
  degauss=0.005
/
&ELECTRONS
  mixing_mode = 'local-TF'
  conv_thr = 1.0D-5
  mixing_beta = 0.9
  mixing_ndim=25
  electron_maxstep=100
  startingpot = 'file'
  startingwfc = 'file'
/
