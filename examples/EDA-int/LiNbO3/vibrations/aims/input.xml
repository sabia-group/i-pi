<simulation verbosity='medium'>

  <total_steps>100</total_steps>

  <ffsocket mode='unix' name='FHI-aims' pbc='True'>
    <address>LiNbO3</address>
    <latency>1e-3</latency>
  </ffsocket>

  <output prefix='LiNbO3'>
    <trajectory filename='position'>positions</trajectory>
    <properties filename='properties.out' > [ step, time{femtosecond}, conserved, temperature{kelvin} ] </properties>
  </output>

  <prng>
    <seed>10545</seed>
  </prng>

  <system>
    <forces> <force forcefield='FHI-aims'/> </forces>

    <initialize nbeads='1'>
      <!--file mode='aims' units='angstrom' cell_units='angstrom' > geometry.in </file-->
      <file mode='xyz' units='angstrom' > LiNbO3.xyz </file>
      <velocities mode='thermal' units='kelvin'>30</velocities>
      <cell mode="manual" units="angstrom">[ 5.4247849157365637, 0.0000000000000000, 0.0000000000000000, 3.0435575239874382, 4.4905510877210464, 0.0000000000000000, 3.0432317169843839, 1.6137499892515090, 4.1900534849191997  ]</cell>
    </initialize>

    <!--ensemble>
      <temperature units='kelvin'>30</temperature>
    </ensemble-->

    <motion mode='vibrations'>
      <vibrations>
        <pos_shift>  0.01 </pos_shift>
      </vibrations>
    </motion>

  </system>
</simulation>
