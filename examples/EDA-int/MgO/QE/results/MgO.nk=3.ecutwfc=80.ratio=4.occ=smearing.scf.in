&CONTROL
  calculation = 'scf'
  restart_mode= 'from_scratch'
  prefix      = 'MgO'
  pseudo_dir  = '/home/elia/Google-Drive/google-personal/pseudos'
  outdir      = './outdir/MgO.nk=3'
  tprnfor     = .true.
  tstress     = .false.
  verbosity   = 'high'
  max_seconds = 14000
  !lberry        = .true.
  !gdir          = 1
  !nppstr        = 5
/
&SYSTEM
  ecutwfc = 80
  ecutrho = 320
  ibrav = 0
  nat = 2
  ntyp = 2
  !nspin=2
  occupations = 'smearing'
  smearing='gauss'
  degauss=0.005
/
&ELECTRONS
  mixing_mode = 'local-TF'
  conv_thr = 1.0D-5
  mixing_beta = 0.9
  mixing_ndim=25
  electron_maxstep=100
  startingpot = 'atomic'
  startingwfc = 'atomic+random'
/
ATOMIC_SPECIES
  Mg  24.305   Mg.pbesol-spnl-rrkjus_psl.1.0.0.UPF
  O   15.9994  O.pbesol-n-rrkjus_psl.1.0.0.UPF

ATOMIC_POSITIONS angstrom
  Mg           0.000000 0.000000 0.000000
  O            1.219997 1.725336 2.988370

K_POINTS automatic
  3 3 3 0 0 0

CELL_PARAMETERS angstrom
  2.4399938875       0.8626681120       1.4941850000
  0.0000000000       2.5880043359       1.4941850000
  0.0000000000       0.0000000000       2.9883700000

