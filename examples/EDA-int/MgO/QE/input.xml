<simulation verbosity='medium'>

  <total_steps>10</total_steps>

  <ffsocket mode='unix' name='pw' pbc='True'>
    <address>localhost</address>
    <!--port>0000</port-->
    <!--timeout>100</timeout-->
    <!--latency> 0.01</latency-->
  </ffsocket>

  <output prefix='MgO'>
    <!--trajectory filename='position'>positions</trajectory-->
    <!--properties filename='properties.out' > [ step, time{femtosecond}, conserved, temperature{kelvin} ] </properties-->
    <!--properties filename='properties.out' > [ step, time{femtosecond}, conserved, temperature{kelvin} ] </properties-->
  </output>

  <prng>
    <seed>10545</seed>
  </prng>

  <system>
    <forces> <force forcefield='pw'/> </forces>

    <initialize nbeads='1'>
      <file mode='xyz' units='angstrom' > MgO.xyz </file>
      <velocities mode='thermal' units='kelvin'>20</velocities>
      <cell mode="manual" units="angstrom">[    2.4399938875,       0.8626681120,       1.4941850000,
                                                0.0000000000,       2.5880043359,       1.4941850000,
                                                0.0000000000,       0.0000000000,       2.9883700000 ]</cell>
    </initialize>

    <ensemble>
      <temperature units='kelvin'>20</temperature>
      <!--BEC mode='file'> BEC.scalar.csv </BEC-->         <!-- how to compute/read the BEC tensors -->
      <!--Eamp units='eV/A'> [ 1.0 , 0.0 , 0.0] </Eamp-->  <!-- amplitude of the E-field. basis: cart, dir (direct lattice vectors), rep (reciprocal lattice vectors)-->
      <!--Ephase > 0.1 </Ephase-->                         <!-- units: rad, deg -->
      <!--Efreq units='THz'> 1.0 </Efreq-->                <!-- frequency of the oscillating E-field -->
    </ensemble>

    <!--motion mode='vibrations'>
      <vibrations mode='fd'>
        <pos_shift> 0.001 </pos_shift>
      </vibrations>
    </motion-->

    <motion mode='dynamics'>
      <dynamics mode='nvt'>
        <timestep units='picosecond'>0.1</timestep>
        <thermostat mode="svr">
            <tau units="picosecond"> 0.1 </tau>
        </thermostat>
      </dynamics>
    </motion>

  </system>
</simulation>
