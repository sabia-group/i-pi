  !lelfield      = .false.
/
&SYSTEM
  ecutrho =   400
  ecutwfc =   50
  ibrav = 0
  nat = 2
  nosym = .false.
  ntyp = 2
  occupations = 'fixed'
/
&ELECTRONS
  conv_thr =   4.0000000000d-10
  electron_maxstep = 80
  mixing_beta =   0.4
/
