&CONTROL
  calculation = 'scf'
  !etot_conv_thr =   2.0000000000d-05
  !forc_conv_thr =   1.0000000000d-04
  outdir = './outdir/'
  prefix = 'MgO'
  pseudo_dir = '/home/elia/Google-Drive/google-personal/pseudos'
  !tprnfor = .true.
  !tstress = .true.
  verbosity = 'low'
  !srvaddress='UNIX:MgO:0000'
  lberry        = .true.
  gdir          = 1
